				"kind": "sidebar-editorial"
			},
			"dimensions": {
				"cols": 30,
				"rows": 54
			},
			"bibleTarget": "01-sidebar-v2-editorial-context.png",
			"crops": [
				{
					"id": "full",
					"targetCrop": "full",
					"runtimeCrop": "full"
				}
			]
		},
		{
			"id": "splash-runtime",
			"lane": "runtime",
			"status": "review",
			"dimensions": {
				"cols": 160,
				"rows": 45
			},
			"bibleTarget": "03-splash.png",
			"runtime": {
				"command": "./bin/sumocode.sh",
				"args": [
					"--offline",
					"--no-extensions",
					"--no-session"
				],
				"settleMs": 3000,
				"env": {
					"PI_OFFLINE": "1",
					"SUMO_TUI": "1",
					"TERM": "xterm-256color",
					"COLORTERM": "truecolor",
					"FORCE_COLOR": "3"
				}
			},
			"rejectIfOutputMatches": [
				"ERR_MODULE_NOT_FOUND",
				"Rendered line .* exceeds terminal width",
				"Skipping installed SumoCode extension because this session is already inside an active SumoCode dev checkout",
				"Error \\["
			],
			"crops": [
				{
					"id": "full",
					"targetCrop": "full",
					"runtimeCrop": "full"
				}
			]
		},
		{
			"id": "active-landscape-runtime",
			"lane": "runtime",
			"status": "review",
			"dimensions": {
				"cols": 160,
				"rows": 45
			},
			"bibleTarget": "scene-active.png",
			"runtime": {
				"command": "./bin/sumocode.sh",
				"args": [
					"--offline",
					"--no-extensions",
