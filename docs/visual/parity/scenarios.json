			"cols": 30,
			"rows": 34
		},
		"chat-area": {
			"x": 0,
			"y": 3,
			"cols": 128,
			"rows": 34
		},
		"input-frame": {
			"x": 0,
			"y": 38,
			"cols": 160,
			"rows": 3
		},
		"hint-row": {
			"x": 0,
			"y": 41,
			"cols": 160,
			"rows": 1
		},
		"footer": {
			"x": 0,
			"y": 43,
			"cols": 160,
			"rows": 1
