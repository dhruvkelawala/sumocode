				"env": {
					"PI_OFFLINE": "1",
					"SUMO_TUI": "1",
					"TERM": "xterm-256color",
					"COLORTERM": "truecolor",
					"FORCE_COLOR": "3"
				},
				"inputs": [
					{
						"afterMs": 1800,
						"type": "text",
