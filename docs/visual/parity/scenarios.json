			"component": {
				"kind": "input-frame-typed"
			},
			"dimensions": {
				"cols": 160,
				"rows": 4
			},
			"bibleTarget": "04-active-input-typed.png",
			"crops": [
				{
					"id": "full",
					"targetCrop": "full",
					"runtimeCrop": "full"
				},
				{
					"id": "input-frame",
					"targetCrop": "input-component-frame",
					"runtimeCrop": "input-component-frame",
					"status": "required",
					"threshold": 0.03
				}
			]
		},
		{
			"id": "footer-ready-component",
			"lane": "component",
			"status": "review",
			"component": {
				"kind": "footer-ready"
			},
