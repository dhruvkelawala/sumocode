				{
					"id": "full",
					"targetCrop": "full",
					"runtimeCrop": "full"
				},
				{
					"id": "footer",
					"targetCrop": "footer-component",
					"runtimeCrop": "footer-component",
					"status": "required",
					"threshold": 0.04
				}
			]
		},
		{
			"id": "top-bar-default-component",
			"lane": "component",
			"status": "review",
			"component": {
				"kind": "top-bar-default"
			},
			"dimensions": {
				"cols": 160,
				"rows": 1
			},
