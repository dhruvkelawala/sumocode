{
  "name": "@dhruvkelawala/sumocode",
  "version": "0.1.0",
  "description": "SumoCode \u2014 a Pi extension that makes the terminal AI coding experience feel personal. OpenCode visual language + persistent memory + preattentive status signals.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "sumocode",
    "terminal",
    "ai"
  ],
  "license": "MIT",
  "author": "Dhruv Kelawala",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dhruvkelawala/sumocode.git"
  },
  "pi": {
    "extensions": [
      "src/extension.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "~0.70.0",
    "@mariozechner/pi-coding-agent": "~0.70.0",
    "@mariozechner/pi-tui": "~0.70.0",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "vitest": "vitest",
    "visual": "node scripts/visual.mjs"
  }
}
